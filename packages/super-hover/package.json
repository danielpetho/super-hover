{
  "name": "super-hover",
  "version": "0.1.0",
  "description": "A super tiny library that hit-tests hover every frame. Unlike native :hover, it keeps tracking whatever sits under your pointer while you scroll or when things move on screen.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "hover",
    "scroll",
    "pointer",
    "dom"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielpetho/super-hover.git"
  },
  "author": {
    "name": "Daniel Petho",
    "url": "https://github.com/danielpetho"
  },
  "homepage": "https://github.com/danielpetho/super-hover#readme",
  "bugs": {
    "url": "https://github.com/danielpetho/super-hover/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vue": "^3.5.0"
  }
}
