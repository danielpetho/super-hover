{
  "name": "super-hover",
  "version": "1.0.0",
  "description": "Hit-tested hover state that updates while scrolling",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": ["hover", "scroll", "pointer", "dom"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielpetho/super-hover.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
