{
  "plain": {
    "color": "#111827",
    "backgroundColor": "transparent"
  },
  "styles": [
    {
      "types": ["comment"],
      "style": {
        "color": "#71717a",
        "fontStyle": "italic"
      }
    },
    {
      "types": ["keyword",  "property", "property-access", "attr-name"],
      "style": {
        "color": "#1d4ed8"
      }
    },
    {
      "types": ["tag"],
      "style": {
        "color": "#b45309"
      }
    },
    {
      "types": ["punctuation", "symbol", "dom"],
      "style": {
        "color": "#111827"
      }
    },
    {
      "types": ["definition", "function"],
      "style": {
        "color": "#0f766e"
      }
    },
    {
      "types": ["string", "char", "attr-value"],
      "style": {
        "color": "#7c3aed"
      }
    },
    {
      "types": ["static", "number"],
      "style": {
        "color": "#dc2626"
      }
    }
  ]
}